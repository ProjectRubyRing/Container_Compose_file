{
  "agent": {
    "region": "ap-northeast-1",
    "debug": true
  },
  "logs": {
    "endpoint_override": "http://cloudwatch-logs-mock:8080",
    "force_flush_interval": 5,
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/mnt/logs/app-front*.log",
            "log_group_name": "/local/myapp/efs/app-front",
            "log_stream_name": "front-local",
            "timezone": "UTC"
          },
          {
            "file_path": "/mnt/logs/app-back*.log",
            "log_group_name": "/local/myapp/efs/app-back",
            "log_stream_name": "back-local",
            "timezone": "UTC"
          }
        ]
      }
    }
  }
}
