# ローカル専用のダミー認証情報。cwagent の SigV4 署名を通すためだけの値で、
# 送信先は cloudwatch-logs-mock (署名は検証しない)。実 AWS の値を書かないこと。
[default]
aws_access_key_id = LOCALDUMMYACCESSKEY
aws_secret_access_key = local-dummy-secret-key

[AmazonCloudWatchAgent]
aws_access_key_id = LOCALDUMMYACCESSKEY
aws_secret_access_key = local-dummy-secret-key
